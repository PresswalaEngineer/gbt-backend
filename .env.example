# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
# Public base URL of THIS api (used to build presigned local upload URLs and
# the public URL of locally-stored images). Override in production.
PUBLIC_BASE_URL=http://localhost:4000

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gbt_admin?schema=public

# ----------------------------------------------------------------------------
# Auth (JWT)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace-with-64-byte-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-byte-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# Encryption (AES-256-GCM for at-rest sensitive fields)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 32 bytes / 64 hex chars.
# ----------------------------------------------------------------------------
ENCRYPTION_KEY=replace-with-32-byte-hex-string

# ----------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins
# (admin panel :3000, customer storefront :3001)
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----------------------------------------------------------------------------
# Rate limiting (per IP)
# ----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ----------------------------------------------------------------------------
# Bootstrap admin (used by `npm run db:seed`)
# ----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@gbt.local
SEED_ADMIN_PASSWORD=ChangeMe!2026
SEED_ADMIN_NAME=Root Admin

# ----------------------------------------------------------------------------
# Storage driver
#   local → files written to UPLOAD_LOCAL_DIR and served at UPLOAD_LOCAL_PUBLIC_PATH
#           (great for local dev / demos — no third-party account needed)
#   r2    → S3-compatible Cloudflare R2 (R2_* vars below become required)
# ----------------------------------------------------------------------------
STORAGE_DRIVER=local
UPLOAD_LOCAL_DIR=uploads
UPLOAD_LOCAL_PUBLIC_PATH=/uploads-public

# ----------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible object storage) — ONLY required when
# STORAGE_DRIVER=r2.
# Dashboard: https://dash.cloudflare.com/?to=/:account/r2
#   1. Create a bucket (e.g. gbt-assets)
#   2. Generate an R2 API token (Object Read & Write) and grab the access key + secret
#   3. Find your account ID in the R2 dashboard sidebar
#   4. (Recommended) connect a custom domain or enable the public r2.dev URL,
#      paste the resulting base URL into R2_PUBLIC_BASE_URL
# ----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_PRESIGN_EXPIRES_IN=300
UPLOAD_MAX_SIZE_BYTES=20971520
UPLOAD_ALLOWED_MIME=image/png,image/jpeg,image/webp,image/gif,image/svg+xml,application/pdf

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# TourCMS Marketplace API integration
# Docs: https://www.tourcms.com/support/api/mp/
#   - TOURCMS_API_KEY: per-vendor key (one per supplier channel)
#   - TOURCMS_MARKETPLACE_ID: your marketplace account id (TourCMS issues this)
#   - TOURCMS_DEFAULT_CHANNEL_ID: default supplier channel; 3930 is the public
#     "TourCMS Example Tour Operator" sandbox
# All keys are optional — leave blank to disable the integration; the API will
# only error when an /integrations/tourcms route is actually called.
# ----------------------------------------------------------------------------
TOURCMS_BASE_URL=https://api.tourcms.com
TOURCMS_API_KEY=replace-with-tourcms-api-key
TOURCMS_MARKETPLACE_ID=0
TOURCMS_DEFAULT_CHANNEL_ID=3930

# ----------------------------------------------------------------------------
# Ventrata OCTO API integration
# Docs: https://docs.ventrata.com/  (OCTO spec: https://docs.octo.travel/)
#   - VENTRATA_API_KEY: per-vendor Bearer token issued by Ventrata. Each
#     vendor (Tootbus, Big Bus, etc.) has its own key — swap when changing
#     vendor.
#   - VENTRATA_OCTO_ENV: 'test' for sandbox (recommended for dev), 'live' for
#     real bookings. Sent as the `Octo-Env` header on every call.
#   - VENTRATA_OCTO_CAPABILITIES: capability flags requested via the
#     `Octo-Capabilities` header. Default enables content, pricing, pickups —
#     leave the value as-is unless you know you need to drop one.
# All keys are optional — leave blank to disable the integration; the API will
# only error when an /integrations/ventrata route is actually called.
# ----------------------------------------------------------------------------
VENTRATA_BASE_URL=https://api.ventrata.com/octo
VENTRATA_API_KEY=replace-with-ventrata-vendor-api-key
VENTRATA_OCTO_ENV=test
VENTRATA_OCTO_CAPABILITIES=octo/content,octo/pricing,octo/pickups

# ----------------------------------------------------------------------------
# Stripe (customer storefront payments) — leave blank to keep payments dormant.
# API still boots; POST /payments/bookings/:id/checkout returns 503 until set.
# Use test keys first: STRIPE_SECRET_KEY=sk_test_…, STRIPE_PUBLISHABLE_KEY=pk_test_…,
# STRIPE_WEBHOOK_SECRET=whsec_… (from `stripe listen` or the dashboard).
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Google OAuth (customer "Continue with Google") — leave blank to keep dormant.
# API still boots; POST /auth/customer/google returns 503 until set.
# GOOGLE_CLIENT_ID = OAuth 2.0 Web client ID (…apps.googleusercontent.com).
# Must match NEXT_PUBLIC_GOOGLE_CLIENT_ID in the storefront .env.local.
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=

# ----------------------------------------------------------------------------
# Email (transactional alerts)
#   MAIL_ENABLED=false  → emails are recorded in EmailLog with status SKIPPED
#                          (default for local dev — no real delivery)
#   MAIL_ENABLED=true   → MAIL_HOST + MAIL_FROM_EMAIL must be set; uses
#                          nodemailer. Works with any SMTP provider (SES,
#                          SendGrid, Postmark, Mailgun, Resend SMTP, etc.).
# Recipients per alert type are configured in /alert-settings (admin UI);
# the global default fallback is ALERT_DEFAULT_RECIPIENTS below.
# ----------------------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Global Bus Tour
ALERT_DEFAULT_RECIPIENTS=
ALERT_DAILY_REPORT_CRON=0 9 * * *
ALERT_DAILY_REPORT_TIMEZONE=UTC

# ----------------------------------------------------------------------------
# Currency / FX auto-sync
# Rates are pulled once per day (cron) + once on boot (skipped if already
# synced today, so restarts don't burn rate limit). Settlement is always USD.
#   - FX_SYNC_URL: any free JSON endpoint returning { rates: { CUR: number } }
#     with USD as the base. Default: open.er-api.com (free, no key, ~165 cur).
#     Swappable to Frankfurter (open-source): https://api.frankfurter.dev/v1/latest?base=USD
#   - FX_SYNC_ENABLED=false disables the cron + boot sync (manual button still works)
# ----------------------------------------------------------------------------
FX_BASE_CURRENCY=USD
FX_SYNC_URL=https://open.er-api.com/v6/latest/USD
FX_SYNC_CRON=0 3 * * *
FX_SYNC_ENABLED=true

# ----------------------------------------------------------------------------
# Cart reservations (hold timers + inventory + realtime)
#   - CART_HOLD_MINUTES: how long an added-to-cart seat is held before auto-release
#   - CART_SWEEP_CRON: expiry sweep cadence (default every minute) — durable backstop
#     for the realtime hold:expired push, releases lapsed holds + frees seats
#   - SOCKET_IO_ENABLED=false skips attaching the websocket server (REST + cron
#     still work; clients just won't get live countdown/availability pushes)
# Per-tour seat capacity is set on the Tour (dailyCapacity, null = unlimited);
# only internal (apiType=NONE) tours use it — vendor tours defer to the operator.
# ----------------------------------------------------------------------------
CART_HOLD_MINUTES=20
CART_SWEEP_CRON=* * * * *
SOCKET_IO_ENABLED=true
